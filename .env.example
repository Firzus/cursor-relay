# Cloudflare named tunnel — required to expose the proxy publicly for Cursor.
# Cursor routes BYOK requests through its cloud backend, so a localhost URL is
# rejected ("Access to private networks is forbidden"). A public HTTPS hostname
# is mandatory. Create a named tunnel and grab its token + hostname.
CLOUDFLARE_TUNNEL_TOKEN=
CLOUDFLARE_TUNNEL_HOSTNAME=

# Local HTTP port bound to 127.0.0.1.
PORT=8787

# Set to 1 to dump SSE traffic and verbose tunnel logs.
DEBUG_LOG=
